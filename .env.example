########################################
# Kafka
########################################

KAFKA_IMAGE=apache/kafka:3.7.0
KAFKA_CONTAINER_PORT=9092
KAFKA_EXTERNAL_LISTENER_PORT=9094
KAFKA_EXTERNAL_PORT=9094
KAFKA_CONTROLLER_PORT=9093
KAFKA_NODE_ID=1
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
KAFKA_UI_PORT=8080

KAFKA_RETRY_ATTEMPTS=3
KAFKA_RETRY_DELAY_SECONDS=2
KAFKA_DLQ_TOPIC=dlq

########################################
# Postgres
########################################

POSTGRES_IMAGE=postgres:16-alpine

########################################
# Docker
########################################

DOCKER_NETWORK_NAME=trocas-network

########################################
# BFF
########################################

BFF_HOST=0.0.0.0
BFF_PORT=8000
BFF_KAFKA_REPLY_TIMEOUT_SECONDS=10

########################################
# Users Service
########################################

USERS_HOST=0.0.0.0
USERS_PORT=8001

USERS_DB_HOST=users-db
USERS_DB_PORT=5432
USERS_DB_NAME=users_db
USERS_DB_USER=postgres
USERS_DB_PASSWORD=postgres

USERS_DB_REPLICATION_USER=replicator
USERS_DB_REPLICATION_PASSWORD=replicator_password

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

########################################
# Ads Service
########################################

ADS_HOST=0.0.0.0
ADS_PORT=8002

ADS_DB_HOST=ads-db
ADS_DB_PORT=5432
ADS_DB_NAME=ads_db
ADS_DB_USER=postgres
ADS_DB_PASSWORD=postgres

ADS_DB_REPLICATION_USER=replicator
ADS_DB_REPLICATION_PASSWORD=replicator_password

########################################
# Trades Service
########################################

TRADES_HOST=0.0.0.0
TRADES_PORT=8003

TRADES_DB_HOST=trades-db
TRADES_DB_PORT=5432
TRADES_DB_NAME=trades_db
TRADES_DB_USER=postgres
TRADES_DB_PASSWORD=postgres

TRADES_DB_REPLICATION_USER=replicator
TRADES_DB_REPLICATION_PASSWORD=replicator_password

TRADES_KAFKA_REPLY_TIMEOUT_SECONDS=10

########################################
# Notifications Service
########################################

NOTIFICATIONS_HOST=0.0.0.0
NOTIFICATIONS_PORT=8004

NOTIFICATIONS_DB_HOST=notifications-db
NOTIFICATIONS_DB_PORT=5432
NOTIFICATIONS_DB_NAME=notifications_db
NOTIFICATIONS_DB_USER=postgres
NOTIFICATIONS_DB_PASSWORD=postgres

NOTIFICATIONS_DB_REPLICATION_USER=replicator
NOTIFICATIONS_DB_REPLICATION_PASSWORD=replicator_password
